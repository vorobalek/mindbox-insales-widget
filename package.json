{
  "name": "mindbox-insales-widget",
  "version": "1.3.48",
  "private": true,
  "description": "Mindbox widget for inSales",
  "packageManager": "npm@11.11.0",
  "scripts": {
    "prepare": "husky",
    "commitlint": "commitlint --from HEAD~1 --to HEAD",
    "typecheck": "tsc --project tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:bundle": "vite build && node scripts/apply-widget-version.mjs",
    "build": "npm run typecheck && npm run build:bundle",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --project=chromium --headed"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=11.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.4",
    "browserslist": "^4.28.2",
    "browserslist-to-esbuild": "^2.1.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "liquidjs": "^10.27.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
