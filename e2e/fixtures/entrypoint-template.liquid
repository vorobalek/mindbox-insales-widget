<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>
    (function() {
      const subscribers = {};
      window.__mindboxCalls = [];
      window.__mindboxConsoleLogs = [];
      const serializeConsoleArg = function(value) {
        if (value instanceof Error) {
          return {
            name: value.name,
            message: value.message,
            stack: value.stack
          };
        }

        if (typeof value === 'undefined') {
          return '[undefined]';
        }

        if (typeof value === 'function') {
          return '[function ' + (value.name || 'anonymous') + ']';
        }

        if (typeof value === 'symbol') {
          return value.toString();
        }

        return value;
      };
      ['log', 'info', 'warn', 'error'].forEach(function(level) {
        const original = console[level];
        if (typeof original !== 'function') {
          return;
        }

        console[level] = function() {
          window.__mindboxConsoleLogs.push({
            level: level,
            args: Array.prototype.slice.call(arguments).map(serializeConsoleArg)
          });

          if (typeof window.__updateE2eDebugBlocks === 'function') {
            window.__updateE2eDebugBlocks();
          }

          return original.apply(this, arguments);
        };
      });
      const customerData = {
        id: {% if customer_data and customer_data.id != nil %}{{ customer_data.id | json }}{% else %}null{% endif %},
        phone: {% if customer_data and customer_data.phone != nil %}{{ customer_data.phone | json }}{% else %}null{% endif %},
        authorized: {% if customer_data and customer_data.authorized %}true{% else %}false{% endif %}
      };
      window.EventBus = {
        subscribe: function(eventName, handler) {
          if (!subscribers[eventName]) {
            subscribers[eventName] = [];
          }
          subscribers[eventName].push(handler);
        }
      };
      window.__emitEventBus = function(eventName, payload) {
        const handlers = subscribers[eventName] || [];
        handlers.forEach(function(handler) {
          handler(payload);
        });
      };
      window.__setCustomerData = function(nextCustomerData) {
        if (!nextCustomerData || typeof nextCustomerData !== 'object') {
          return;
        }

        if (Object.prototype.hasOwnProperty.call(nextCustomerData, 'id')) {
          customerData.id = nextCustomerData.id;
        }
        if (Object.prototype.hasOwnProperty.call(nextCustomerData, 'phone')) {
          customerData.phone = nextCustomerData.phone;
        }
        if (Object.prototype.hasOwnProperty.call(nextCustomerData, 'authorized')) {
          customerData.authorized = Boolean(nextCustomerData.authorized);
        }
      };
      window.ajaxAPI = {
        shop: {
          client: {
            get: function() {
              const payload = {
                id: customerData.id,
                phone: customerData.phone
              };
              return {
                done: function(callback) {
                  if (customerData.authorized) {
                    callback(payload);
                  }
                  return this;
                },
                fail: function(callback) {
                  if (!customerData.authorized) {
                    callback({ message: 'Not authorized' });
                  }
                  return this;
                }
              };
            }
          }
        }
      };
    })();
  </script>
  {%- capture content_for_layout -%}
    {%- render 'entrypoint-page',
      widget_settings: widget_settings,
      template: template,
      collection: collection,
      product: product
    -%}
  {%- endcapture %}
{{- content_for_layout | rstrip }}
  <script type="module" src="/src/snippet.ts"></script>
</head>
<body></body>
</html>
